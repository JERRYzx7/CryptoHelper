# ── Crypto Scanner 環境設定 ──────────────────────────────────────────────────
# 複製此檔案為 .env 並填入真實值：  cp .env.example .env

# ── Telegram 設定（必填）────────────────────────────────────────────────────

# Bot Token — 取得步驟：
#   1. Telegram 搜尋 @BotFather → 發送 /newbot
#   2. 照指示命名 bot，BotFather 回傳 token（格式：1234567890:ABCxyz）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID — 取得步驟（擇一）：
#   個人：Telegram 搜尋 @userinfobot，發訊息後它會回覆你的數字 ID
#   群組：把 bot 加入群組後訪問 https://api.telegram.org/bot<TOKEN>/getUpdates
#         找 "chat":{"id": -100xxxxxxxxx}（群組 ID 為負數）
TELEGRAM_CHAT_ID=your_chat_id_here

# ── 可選：State 檔案目錄（預設：專案根目錄）───────────────────────────────
# 部署到 Fly.io 時設為 /data（對應 persistent volume）
# STATE_DIR=/data
